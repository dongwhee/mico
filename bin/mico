#!/usr/bin/env bash
# mico — launch Claude as a plan-only orchestrator.
# Implementation/research/investigation are delegated to specialist subagents
# (implementer, web-researcher, code-investigator, ...) installed from agents/.
#
# Setup:  mico install | uninstall | update | setup
#   install    symlink agents/skills/scripts into ~/.claude and mico into ~/.local/bin
#              (existing real files are backed up as <name>.pre-mico)
#   uninstall  remove the symlinks, restore backups
#   update     git pull the repo (symlinks pick up changes automatically)
#   setup      run headless Claude in the CURRENT project to align its docs with
#              mico conventions (CLAUDE.md plan-distinction note + .gitignore .mico/)
#              and report other-doc conflicts; then recommend installing jq if missing
#
# Usage: mico [--orch fable|opus] [--impl opus|codex] [--codex-effort minimal|low|medium|high|xhigh] [claude args...]
#   --orch          orchestrator model (default: opus). `opus` is the lighter mode:
#                   it adds `--effort xhigh` (official rec for agentic/planning work).
#                   In every mode the advisor defaults to the orch model
#                   (`--advisor opus|fable`) unless you pass your own --advisor.
#   --impl          implementation backend (default: opus -> implementer agent;
#                   codex -> codex-delegate skill, build mode)
#   --codex-effort  codex reasoning effort, exported as CODEX_DELEGATE_EFFORT
#                   (default: xhigh when --impl codex; script default otherwise)
# Unrecognized args are passed through to claude (e.g. --effort, --continue).
set -uo pipefail

self=$(readlink -f "$0")
repo=$(cd "$(dirname "$self")/.." && pwd)

# ---- install / uninstall / update ------------------------------------------

# manifest: one "dst|src" per line
links() {
  cat <<EOF
$HOME/.local/bin/mico|$repo/bin/mico
$HOME/.claude/scripts/codex-delegate.sh|$repo/scripts/codex-delegate.sh
$HOME/.claude/scripts/orchestrator-guard.sh|$repo/scripts/orchestrator-guard.sh
$HOME/.claude/skills/codex-delegate|$repo/skills/codex-delegate
$HOME/.claude/agents/implementer.md|$repo/agents/implementer.md
$HOME/.claude/agents/web-researcher.md|$repo/agents/web-researcher.md
$HOME/.claude/agents/code-investigator.md|$repo/agents/code-investigator.md
$HOME/.claude/agents/git-runner.md|$repo/agents/git-runner.md
$HOME/.claude/agents/lightweight-runner.md|$repo/agents/lightweight-runner.md
EOF
}

# Backups must live OUTSIDE ~/.claude/skills|agents — Claude Code discovers
# anything left there (a skills/<name>.pre-mico dir shows up as a real skill).
backup_dir="$HOME/.claude/backups/mico"

cmd_install() {
  links | while IFS='|' read -r dst src; do
    mkdir -p "$(dirname "$dst")"
    if [ -e "$dst" ] && [ ! -L "$dst" ]; then
      mkdir -p "$backup_dir"
      mv "$dst" "$backup_dir/$(basename "$dst")"
      echo "mico: backed up $dst -> $backup_dir/$(basename "$dst")"
    fi
    ln -sfn "$src" "$dst"
    echo "mico: linked   $dst"
  done
  echo "mico: install complete (repo: $repo)"
}

cmd_uninstall() {
  links | while IFS='|' read -r dst src; do
    if [ -L "$dst" ] && [ "$(readlink "$dst")" = "$src" ]; then
      rm "$dst"
      echo "mico: removed  $dst"
    fi
    if [ -e "$backup_dir/$(basename "$dst")" ]; then
      mv "$backup_dir/$(basename "$dst")" "$dst"
      echo "mico: restored $dst"
    fi
  done
  rmdir "$backup_dir" 2>/dev/null
  echo "mico: uninstall complete"
}

cmd_update() {
  git -C "$repo" pull --ff-only
  echo "mico: update complete (symlinked installs pick this up automatically)"
}

# Run headless Claude in the CURRENT working directory to align this project's
# docs with mico conventions (one-shot, non-orchestrator: it MUST be able to edit
# files, so no plan-only guard here).
cmd_setup() {
  local prompt="$repo/prompts/setup-prompt.md"
  if [ ! -f "$prompt" ]; then
    echo "mico: setup prompt not found at $prompt" >&2
    exit 1
  fi
  echo "mico: starting setup in $PWD; this may take a minute. Claude may be quiet while reading/updating docs..." >&2
  # --model opus: fable is currently blocked; opus is the standardized default.
  # acceptEdits + explicit --allowedTools so reads and the CLAUDE.md/.gitignore
  # edits run without a prompt under headless mode (Bash is intentionally excluded
  # so the session cannot edit via Bash — see the prompt's "never use Bash" rule).
  # Not exec'd: we run claude, then print a final environment advisory below.
  local heartbeat_pid rc
  (
    while sleep 20; do
      echo "mico: setup still running..." >&2
    done
  ) &
  heartbeat_pid=$!
  trap 'kill "$heartbeat_pid" 2>/dev/null; wait "$heartbeat_pid" 2>/dev/null' EXIT

  claude -p "$(cat "$prompt")" \
    --no-session-persistence \
    --model opus \
    --permission-mode acceptEdits \
    --allowedTools "Read,Grep,Glob,Edit,Write"
  rc=$?
  kill "$heartbeat_pid" 2>/dev/null
  wait "$heartbeat_pid" 2>/dev/null
  trap - EXIT

  # Final advisory (the script recommends, not the agent): the plan-only guard
  # relies on jq to parse the hook payload and grant the orchestrator its
  # plan/memory-doc edit exemptions. Without jq the guard falls back to blocking
  # ALL main-agent edits, so the orchestrator can't even edit its own plan/memory
  # docs. Recommend installing it.
  if ! command -v jq >/dev/null 2>&1; then
    echo >&2
    echo "mico: NOTE — 'jq' was not found on this machine. mico's plan-only guard" >&2
    echo "      needs jq to let the orchestrator edit plan/memory docs directly;" >&2
    echo "      without it, every orchestrator edit is blocked and must be delegated." >&2
    echo "      Recommended install:" >&2
    echo "        macOS: brew install jq  |  Debian/Ubuntu: sudo apt install jq" >&2
    echo "        Fedora: sudo dnf install jq  (or use your package manager)" >&2
  fi
  exit $rc
}

usage() {
  cat <<'EOF'
mico — launch Claude as a plan-only orchestrator.
Implementation/research/investigation are delegated to specialist subagents.

Usage:
  mico [--orch fable|opus] [--impl opus|codex] [--codex-effort LEVEL] [claude args...]
  mico install | uninstall | update | setup
  mico --help | -h

Setup commands:
  install     symlink agents/skills/scripts into ~/.claude and mico into ~/.local/bin
              (existing real files are backed up under ~/.claude/backups/mico)
  uninstall   remove the symlinks, restore backups
  update      git pull the repo (symlinks pick up changes automatically)
  setup       run headless Claude in the CURRENT project folder to align its docs
              with mico conventions (CLAUDE.md plan-distinction note + .gitignore
              .mico/) and report other-doc conflicts; recommends jq if it is missing

Launcher options:
  --orch fable|opus
              orchestrator model (default: opus). opus adds --effort xhigh
              (unless overridden). The advisor defaults to the orch model via
              --advisor (opus->opus, fable->fable) unless you pass --advisor.
  --impl opus|codex
              implementation backend (default: opus -> implementer agent;
              codex -> codex-delegate skill, build mode).
  --codex-effort minimal|low|medium|high|xhigh
              codex reasoning effort, exported as CODEX_DELEGATE_EFFORT
              (default: xhigh when --impl codex).

Any other arguments are passed through to claude (e.g. --continue, --resume, --effort).
EOF
}

case "${1:-}" in
  install)   cmd_install;   exit 0 ;;
  uninstall) cmd_uninstall; exit 0 ;;
  update)    cmd_update;    exit $? ;;
  setup)     cmd_setup;     exit $? ;;
esac

# ---- launcher ---------------------------------------------------------------

orch=opus
impl=opus
codex_effort=""
args=()
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help)      usage; exit 0 ;;
    --orch)         orch=${2:?--orch needs a value};                 shift 2 ;;
    --impl)         impl=${2:?--impl needs a value};                 shift 2 ;;
    --codex-effort) codex_effort=${2:?--codex-effort needs a value}; shift 2 ;;
    *)              args+=("$1"); shift ;;
  esac
done

case "$orch" in
  fable|opus) ;;
  *) echo "mico: unknown --orch '$orch' (expected fable|opus)" >&2; exit 2 ;;
esac
case "$impl" in
  opus|codex) ;;
  *) echo "mico: unknown --impl '$impl' (expected opus|codex)" >&2; exit 2 ;;
esac
if [ -n "$codex_effort" ]; then
  case "$codex_effort" in
    minimal|low|medium|high|xhigh) export CODEX_DELEGATE_EFFORT=$codex_effort ;;
    *) echo "mico: unknown --codex-effort '$codex_effort' (expected minimal|low|medium|high|xhigh)" >&2; exit 2 ;;
  esac
fi

base_prompt="$repo/prompts/orchestrator-prompt.md"
prompt_file=$base_prompt
if [ "$impl" = codex ]; then
  : "${CODEX_DELEGATE_EFFORT:=xhigh}"
  export CODEX_DELEGATE_EFFORT
  prompt_file=$(mktemp -t mico-prompt.XXXXXX)
  cat "$base_prompt" >"$prompt_file"
  cat >>"$prompt_file" <<EOF

## Session override: implementation backend

For THIS session, route code writing/modification to the \`codex-delegate\` skill
(build mode, reasoning effort: $CODEX_DELEGATE_EFFORT — already exported as
CODEX_DELEGATE_EFFORT; do not set it yourself) instead of the \`implementer\` agent.
Codex tends to expand scope, so every spec you hand it must include:
"Implement ONLY this spec. Do not expand scope or suggest extra tasks."
If codex fails or the task needs surgical multi-file reasoning, fall back to the
\`implementer\` agent (Opus).
EOF
fi

# Plan-only guard. A session deny (--disallowedTools) would strip Edit/Write from
# the shared tool pool that subagents inherit, breaking delegation. Instead inject
# a PreToolUse hook that blocks Edit/Write/NotebookEdit for the MAIN orchestrator
# only and exempts subagents (see scripts/orchestrator-guard.sh). It is injected
# via --settings so it applies to THIS session only, never the user's global
# ~/.claude/settings.json. --settings merges with the settings hierarchy, so the
# user's own hooks/permissions are preserved.
#
# The session settings ALSO carry a safe-git allowlist so the orchestrator can run
# basic read git plus add/commit/etc. without permission prompts. Only safe verbs
# are allowed; destructive sub-flags of an allowed prefix are denied. branch/tag
# prompt like other less-common git because prefix rules can't constrain their
# long-form destructive flags (--delete, -M, -f). Destructive/outbound git (push,
# reset, checkout, switch, restore, clean, rebase) is intentionally omitted so it
# keeps prompting.
guard="$repo/scripts/orchestrator-guard.sh"
guard_hook="\"hooks\":{\"PreToolUse\":[{\"matcher\":\"Edit|Write|NotebookEdit\",\"hooks\":[{\"type\":\"command\",\"command\":\"$guard\"}]}]}"
git_perms="\"permissions\":{\"allow\":[\"Bash(git status:*)\",\"Bash(git diff:*)\",\"Bash(git log:*)\",\"Bash(git show:*)\",\"Bash(git add:*)\",\"Bash(git commit:*)\",\"Bash(git stash:*)\",\"Bash(git fetch:*)\",\"Bash(git pull:*)\",\"Bash(git mv:*)\",\"Bash(git rev-parse:*)\",\"Bash(git ls-files:*)\",\"Bash(git blame:*)\"],\"deny\":[\"Bash(git stash drop:*)\",\"Bash(git stash clear:*)\"]}"

# Detect caller overrides so we don't fight them.
has_effort=false has_settings=false has_advisor=false
for a in "${args[@]+"${args[@]}"}"; do
  case "$a" in
    --effort|--effort=*)     has_effort=true ;;
    --settings|--settings=*) has_settings=true ;;
    --advisor|--advisor=*)   has_advisor=true ;;
  esac
done

# The plan-only guard hook and safe-git allowlist are always injected. The advisor
# is set via the --advisor flag below (not advisorModel here) so it survives even
# if the caller passes their own --settings.
mico_settings="{$guard_hook,$git_perms}"

claude_args=(
  --model "$orch"
  --append-system-prompt-file "$prompt_file"
  --settings "$mico_settings"
)
# Opus mode: xhigh effort (official rec for agentic/planning), unless overridden.
if [ "$orch" = opus ]; then
  $has_effort || claude_args+=(--effort xhigh)
fi

# Advisor defaults to the orchestrator model itself (opus->opus, fable->fable; a
# same-or-stronger pairing is always valid) unless the caller passed --advisor.
$has_advisor || claude_args+=(--advisor "$orch")
# --settings is single-value; a user-supplied one would override our guard hook.
if $has_settings; then
  echo "mico: warning — your --settings overrides mico's plan-only guard hook; the orchestrator will be able to edit files directly." >&2
fi

exec claude "${claude_args[@]}" "${args[@]+"${args[@]}"}"
